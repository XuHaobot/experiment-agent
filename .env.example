# OpenAI-compatible Chat Completions API key.
# Leave empty to use rule-based extraction only.
LLM_API_KEY=

# Base URL without the final /chat/completions path.
# Examples:
# - https://api.openai.com/v1
# - https://your-openai-compatible-endpoint/v1
LLM_BASE_URL=https://api.openai.com/v1

# Model name provided by your API endpoint.
# Examples:
# - gpt-4o-mini
# - gpt-4.1-mini
# - your-compatible-model-name
LLM_MODEL=

# DashScope API Key (通义千问)
# 用于 text-embedding-v2 向量语义搜索功能
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=
